# Supabase Database Configuration
NEXT_PUBLIC_SUPABASE_URL=https://rzbswspqzhnmfrltocua.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_secret

# Resend Email Service Configuration (server-only; never use NEXT_PUBLIC_)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM="SyncUT <notificaciones@your_verified_domain>"
EMAIL_QUEUE_TRIGGER_TOKEN=your_long_random_email_queue_token
EMAIL_BATCH_SIZE=10

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel Configuration (Optional for local development, required for CI/CD)
VERCEL_TOKEN=your_vercel_personal_access_token
# IA conversacional gratuita (crear clave en https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
